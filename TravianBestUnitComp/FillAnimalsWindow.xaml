        <Label x:Name="lblCroc" Content="Croc" HorizontalAlignment="Left" Margin="290,10,0,0" VerticalAlignment="Top" Width="44" HorizontalContentAlignment="Center"/>
        <Label x:Name="lblTiger" Content="Tiger" HorizontalAlignment="Left" Margin="330,10,0,0" VerticalAlignment="Top" Width="44" HorizontalContentAlignment="Center"/>
        <Label x:Name="lblElephant" Content="Elephant" HorizontalAlignment="Left" Margin="370,10,0,0" VerticalAlignment="Top" Width="60" HorizontalContentAlignment="Center"/>
        <TextBox x:Name="txtRat" HorizontalAlignment="Left" Margin="16,36,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="32"/>
        <TextBox x:Name="txtSpider" HorizontalAlignment="Left" Margin="56,36,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="32"/>
        <TextBox x:Name="txtSnake" HorizontalAlignment="Left" Margin="96,36,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="32"/>
