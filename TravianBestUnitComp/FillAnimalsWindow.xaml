        xmlns:local="clr-namespace:TravianBestUnitComp"
        mc:Ignorable="d"
        Title="FillAnimalsWindow" Height="150" Width="445">
    <Grid>
        <Label x:Name="lblRat" Content="Rat" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="44" HorizontalContentAlignment="Center"/>
        <Label x:Name="lblSpider" Content="Spider" HorizontalAlignment="Left" Margin="50,10,0,0" VerticalAlignment="Top" Width="44" HorizontalContentAlignment="Center"/>
        <Label x:Name="lblSnake" Content="Snake" HorizontalAlignment="Left" Margin="90,10,0,0" VerticalAlignment="Top" Width="44" HorizontalContentAlignment="Center"/>
