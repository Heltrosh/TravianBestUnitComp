        <TextBox x:Name="txtBoar" HorizontalAlignment="Left" Margin="176,36,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="32"/>
        <TextBox x:Name="txtWolf" HorizontalAlignment="Left" Margin="216,36,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="32"/>
        <TextBox x:Name="txtBear" HorizontalAlignment="Left" Margin="256,36,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="32"/>
        <TextBox x:Name="txtCroc" HorizontalAlignment="Left" Margin="296,36,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="32"/>
        <TextBox x:Name="txtTiger" HorizontalAlignment="Left" Margin="336,36,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="32"/>
        <TextBox x:Name="txtElephant" HorizontalAlignment="Left" Margin="384,36,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="32"/>
        <Button x:Name="btnConfirm" Content="Confirm" HorizontalAlignment="Left" Margin="201,67,0,0" VerticalAlignment="Top" Width="62" Click="btnConfirm_Click"/>

    </Grid>
</Window>
